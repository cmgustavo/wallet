{
  "name": "simplewallet",
  "version": "1.0.10",
  "author": "Gustavo Cortez",
  "homepage": "https://github.com/cmgustavo/wallet",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration development && npx cap copy && npx cap open android",
    "prod": "ng build --configuration production && npx cap copy && npx cap open android",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "release": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "release:build": "node scripts/release.js --build-only",
    "release:dry": "node scripts/release.js patch --dry-run"
  },
  "private": true,
